QWEN_API_KEY=sk-your-qwen-key-here

# SQL Server 数据库配置
DB_SERVER=localhost
DB_DATABASE=hometown_practice

# 本地开发用 Windows 认证
DB_TRUSTED_CONNECTION=yes

# 部署到服务器用账号密码（有值时优先使用，覆盖 Trusted_Connection）
DB_USER=
DB_PASSWORD=

# Session 密钥（生产环境请修改为随机字符串）
SECRET_KEY=dev-secret-key-change-in-production

# 管理员配置
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-admin-password
